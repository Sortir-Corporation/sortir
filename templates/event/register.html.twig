{% extends 'base.html.twig' %}

{% block title %}Inscription à {{ event.name }}{% endblock %}

{% block body %}

    <h1>Inscription à l'événement : {{ event.name }}</h1>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="event-details">
        <p><strong>Date :</strong> {{ event.startTime|date('d/m/Y H:i') }}</p>
        <p><strong>Date limite d'inscription :</strong> {{ event.registrationDeadline|date('d/m/Y H:i') }}</p>
        <p><strong>Participants :</strong> {{ event.users|length }} / {{ event.maxParticipants }}</p>
        <p><strong>Campus :</strong> {{ event.campus.name }}</p>
        <p><strong>Lieu :</strong> {{ event.location.name }}</p>

        {% if event.eventInfo %}
            <p><strong>Informations :</strong> {{ event.eventInfo }}</p>
        {% endif %}
    </div>

    <hr>

    <h3>Confirmer votre inscription</h3>

    <p>Souhaitez-vous vous inscrire à cet événement ?</p>

    <form method="post">
        <button type="submit" class="btn btn-primary">
            Confirmer l'inscription
        </button>

        <a href="{{ path('events', { id: event.id }) }}" class="btn btn-secondary">
            Retour
        </a>
    </form>

{% endblock %}
