{% extends 'base.html.twig' %}

{% block body %}
    {# We combine the layout class (.form-container) with the visual class (.glass-panel) #}
    <div class="form-container glass-panel">
        <h1>Create a New Event</h1>

        {# Display any flash messages here #}
        <div class="flash-messages">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {{ form_start(eventForm) }}

        {# SECTION 1: General Information #}
        <fieldset class="form-section">
            <legend>General Details</legend>

            <div class="form-group">
                {{ form_label(eventForm.name, 'Event Name') }}
                {{ form_widget(eventForm.name) }}
                <div class="form-error">
                    {{ form_errors(eventForm.name) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(eventForm.eventInfo, 'Description & Info') }}
                {{ form_widget(eventForm.eventInfo) }}
                <div class="form-error">
                    {{ form_errors(eventForm.eventInfo) }}
                </div>
            </div>
        </fieldset>

        {# SECTION 2: Schedule & Timing #}
        <fieldset class="form-section">
            <legend>Schedule</legend>

            <div class="form-group-row">
                <div class="form-group">
                    {{ form_label(eventForm.startTime, 'Start Time') }}
                    {{ form_widget(eventForm.startTime) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.startTime) }}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(eventForm.duration, 'Duration (minutes)') }}
                    {{ form_widget(eventForm.duration) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.duration) }}
                    </div>
                </div>
            </div>

            <div class="form-group">
                {{ form_label(eventForm.registrationDeadline, 'Registration Deadline') }}
                {{ form_widget(eventForm.registrationDeadline) }}
                <div class="form-error">
                    {{ form_errors(eventForm.registrationDeadline) }}
                </div>
            </div>
        </fieldset>

        {# SECTION 3: Logistics #}
        <fieldset class="form-section">
            <legend>Logistics & Capacity</legend>

            <div class="form-group-row">
                <div class="form-group">
                    {{ form_label(eventForm.maxParticipants, 'Maximum Participants') }}
                    {{ form_widget(eventForm.maxParticipants) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.maxParticipants) }}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(eventForm.location, 'Location') }}
                    {{ form_widget(eventForm.location) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.location) }}
                    </div>
                </div>
            </div>
        </fieldset>

        {# Submit Button #}
        <div class="form-actions">
            <button type="submit" class="btn-primary">Create Event</button>
        </div>

        {# This will now close the form cleanly without dumping any forgotten fields! #}
        {{ form_end(eventForm) }}
    </div>
{% endblock %}
