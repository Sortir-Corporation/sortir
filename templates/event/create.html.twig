{% extends 'base.html.twig' %}

{% block body %}
    {# On vérifie que l'utilisateur est connecté (ROLE_USER ou ROLE_ADMIN par héritage) #}
    {% if is_granted('ROLE_USER') %}
    {# We combine the layout class (.form-container) with the visual class (.glass-panel) #}
    <div class="form-container glass-panel">
        <h1>Créer un évènement</h1>

        {# Display any flash messages here #}
        <div class="flash-messages">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {{ form_start(eventForm, {
            'attr': {
                'novalidate' : 'novalidate'
            }
        }) }}

        {# SECTION 1: General Information #}
        <fieldset class="form-section">

            <div class="form-group">
                {{ form_label(eventForm.name, 'Nom de l\'évènement :') }}
                {{ form_widget(eventForm.name,{
                    attr: { placeholder: '(Exemple : Aller au bar)' }
                }) }}
                <div class="form-error">
                    {{ form_errors(eventForm.name) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(eventForm.eventInfo, 'Description :') }}
                {{ form_widget(eventForm.eventInfo, {
                    attr: {placeholder: 'Votre description...'}
                }) }}
                <div class="form-error">
                    {{ form_errors(eventForm.eventInfo) }}
                </div>
            </div>
        </fieldset>

        {# SECTION 2: Schedule, Timing & Capacity #}
        <fieldset class="form-section">
            <div class="form-group-row">
                <div class="form-group">
                    {{ form_label(eventForm.startTime, 'Date et heure de l\'évènement :') }}
                    {{ form_widget(eventForm.startTime) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.startTime) }}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(eventForm.duration, 'Durée de l\'évènement (en minutes) :') }}
                    {{ form_widget(eventForm.duration,{
                        attr: { placeholder: '(Exemple : 90 minutes)' }
                    }) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.duration) }}
                    </div>
                </div>
            </div>

            {# NEW: Deadline and Participants are now grouped #}
            <div class="form-group-row">
                <div class="form-group">
                    {{ form_label(eventForm.registrationDeadline, 'Date et heure limite d\'inscription :') }}
                    {{ form_widget(eventForm.registrationDeadline) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.registrationDeadline) }}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(eventForm.maxParticipants, 'Nombre attendu de participants :') }}
                    {{ form_widget(eventForm.maxParticipants,{
                        attr: { placeholder: 'Entrer une valeur' }
                    }) }}
                    <div class="form-error">
                        {{ form_errors(eventForm.maxParticipants) }}
                    </div>
                </div>
            </div>
        </fieldset>

        {# SECTION 3: Logistics #}
        <fieldset class="form-section">


            {# NEW: Full width location with flex header #}
            <div class="form-group">
                <div class="label-header">
                    {{ form_label(eventForm.location, 'Lieu') }}
                    <a href="{{ path('location_create') }}" class="add-link">
                        + Ajouter un nouveau lieu
                    </a>
                </div>
                {{ form_widget(eventForm.location) }}
                <div class="form-error">
                    {{ form_errors(eventForm.location) }}
                </div>
            </div>

            <div class="form-group picture-upload-group">

                {# Get the exact ID Symfony generated for this field #}
                {% set imageInputId = eventForm.eventPicture.vars.id %}

                {# Our custom Glass Button, linked to the hidden Symfony widget #}
                <label id="uploadLabel" class="picture-upload-label " for="{{ imageInputId }}">
                    <span class="upload-text">Image de l'évènement : <span class="action-text">Choisir une image</span></span>
                </label>

                {# The actual Symfony widget, hidden from view but handling the real data #}
                <div style="display: none;">
                    {{ form_widget(eventForm.eventPicture, {
                        'attr': {'class': 'hidden-symfony-file-input'}
                    }) }}
                </div>

                {# Keep the errors visible right below the button! #}
                <div class="form-error">
                    {{ form_errors(eventForm.eventPicture) }}
                </div>

            </div>
        </fieldset>

{#        <fieldset class="form-section">#}
{#            <div class="form-group picture-upload-group">#}
{#                <label id="uploadLabel" class="picture-upload-label glass-panel" for="imageUpload">#}
{#                    <span class="upload-text">Image de l'évènement : <span class="action-text">Choisir une image</span></span>#}
{#                </label>#}
{#                <input type="file" id="imageUpload" style="display: none;" accept="image/*">#}
{#                }</div>#}
{#        </fieldset>#}

        {# Submit Button #}
        <div class="form-actions">
            <button type="submit" class="btn-primary">Créer</button>
        </div>

        {# This will now close the form cleanly without dumping any forgotten fields! #}
        {{ form_end(eventForm) }}
    </div>
    {%  endif %}
{% endblock %}

{% block javascripts %}

    <script src="{{ asset('js/image-upload.js') }}"></script>

{% endblock %}
