{% extends 'base.html.twig' %}

{% block title %}Afficher une sortie{% endblock %}

{% block body %}
    {# On vérifie que l'utilisateur est connecté (ROLE_USER ou ROLE_ADMIN par héritage) #}
    {% if is_granted('ROLE_USER') %}
    <div>

        <h1>Afficher une sortie</h1>

        <div>

            <div>
                <h1>{{ event.name }}</h1>

                {% if event.image %}
                    <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="Image de l'événement" width="300">
                {% endif %}
            </div>

            <div>
                <strong>Nom de la sortie :</strong>
                <span>{{ event.name }}</span>
            </div>

            <div>
                <strong>Statut de la sortie :</strong>
                <span>{{ event.status.value }}</span>
            </div>

            <div>
                <strong>Date et heure de la sortie :</strong>
                <span>{{ event.startTime|date('d/m/Y H:i') }}</span>
            </div>

            <div>
                <strong>Date limite d'inscription :</strong>
                <span>{{ event.registrationDeadline|date('d/m/Y H:i') }}</span>
            </div>

            <div>
                <strong>Nombre de places :</strong>
                <span>{{ event.maxParticipants }}</span>
            </div>

            <div>
                <strong>Durée :</strong>
                <span>{{ event.duration }} minutes</span>
            </div>

            <div>
                <strong>Description et infos :</strong>
                <p>{{ event.eventInfo }}</p>
            </div>

            <div>
                <strong>Ville organisatrice :</strong>
                <span>{{ event.campus.name }}</span>
            </div>

            <div>
                <strong>Lieu :</strong>
                <span>{{ event.location.name }}</span>
            </div>

            <div>
                <strong>Rue :</strong>
                <span>{{ event.location.street }}</span>
            </div>

            <div>
                <strong>Code postal :</strong>
                <span>{{ event.location.city.zipCode }}</span>
            </div>

            <div>
                <strong>Latitude :</strong>
                <span>{{ event.location.latitude }}</span>
            </div>

            <div>
                <strong>Longitude :</strong>
                <span>{{ event.location.longitude }}</span>
            </div>

        </div>

        <h3>Liste des participants inscrits :</h3>

        <table>
            <thead>
            <tr>
                <th>Pseudo</th>
                <th>Nom</th>
                <th>Action</th>
            </tr>
            </thead>
            <tbody>
            {% for user in event.users %}
                <tr>
                    {# Le pseudo devient un lien vers la page détails du profil #}
                    <td>
                        <a href="{{ path('user_details', {id: user.id}) }}">{{ user.alias }}</a>
                    </td>
                    {# Attention au CamelCase : firstname -> firstName, lastname -> lastName #}
                    <td>{{ user.firstName }} {{ user.lastName }}</td>
                    <td>
                        {# L'action "Se désinscrire" n'apparaît QUE sur la ligne de l'utilisateur connecté #}
                        {% if app.user and app.user.id == user.id %}
                            <a href="{{ path('events_unRegister', {id: event.id}) }}" class="btn-unregister">Se désinscrire</a>
                        {% else %}
                            <span class="text-muted">-</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    {# colspan="3" pour que le message prenne toute la largeur des 3 colonnes proprement #}
                    <td colspan="3">Aucun participant inscrit pour le moment.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div>
            <a href="{{ path('app_home') }}">Retour</a>

            {% if app.user and not event.users.contains(app.user) %}
                <a href="{{ path('events_register', {id: event.id}) }}">S'inscrire</a>
            {% endif %}
        </div>

        <div>
            {% if event.status.name == 'CREATED' %}
                {# on reconstruit le formulaire en intégrant le token CSRF et en désactivant explicitement Turbo (via data-turbo="false") pour être certain que Symfony reçoive la requête HTTP standard complète. #}
                <form action="{{ path('events_publish', {'id': event.id}) }}" method="POST" data-turbo="false">
                    <input type="hidden" name="_token" value="{{ csrf_token('publish' ~ event.id) }}">

                    <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Voulez-vous vraiment publier cette sortie ? Les inscriptions seront ouvertes.');">
                        Publier la sortie
                    </button>
                </form>
            {% endif %}
        </div>

        <div>
            {# L'utilisateur doit être l'organisateur ET l'événement ne doit être ni en cours, ni passé #}
            {% if app.user and event.organizer.id == app.user.id %}
                {% if event.status.name != 'IN_PROGRESS' and event.status.name != 'PAST' %}

                    <form action="{{ path('events_cancel', {'id': event.id}) }}" method="POST" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ event.id) }}">

                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Êtes-vous absolument sûr de vouloir annuler définitivement cet événement ? Cette action est irréversible.');">
                            Annuler l'événement
                        </button>
                    </form>

                {% endif %}
            {% endif %}
        </div>
        <div>
        </div>
    </div>
    {% endif %}
{% endblock %}
