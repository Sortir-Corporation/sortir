<div class="profile-container">
    <h2>Modifier le profil</h2>

    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
    {{ form_errors(form) }}

    {# Case à cocher pour désactiver le compte (ADMIN UNIQUEMENT) #}
    {% if is_granted('ROLE_ADMIN') %}
        <div class="admin-zone alert alert-warning">
            {{ form_row(form.active, {'label': 'Compte actif (Décocher pour désactiver)'}) }}
        </div>
    {% else %}
        {% do form.active.setRendered() %}
    {% endif %}

    <hr>

    {% set is_owner = (app.user and app.user.id == user.id) %}

    {# GESTION DES CHAMPS SELON LE RÔLE #}
    <div class="form-group">
        <label>Pseudo :</label>
        {% if is_owner %}
            {{ form_widget(form.alias) }}
            {{ form_errors(form.alias) }}
        {% else %}
            <p class="form-control-static">{{ user.alias }}</p>
            {% do form.alias.setRendered() %}
        {% endif %}
    </div>

    <div class="form-group">
        <label>Prénom :</label>
        {% if is_owner %}
            {{ form_widget(form.firstName) }}
            {{ form_errors(form.firstName) }}
        {% else %}
            <p class="form-control-static">{{ user.firstName }}</p>
            {% do form.firstName.setRendered() %}
        {% endif %}
    </div>

    <div class="form-group">
        <label>Nom :</label>
        {% if is_owner %}
            {{ form_widget(form.lastName) }}
            {{ form_errors(form.lastName) }}
        {% else %}
            <p class="form-control-static">{{ user.lastName }}</p>
            {% do form.lastName.setRendered() %}
        {% endif %}
    </div>

    <div class="form-group">
        <label>Téléphone :</label>
        {% if is_owner %}
            {{ form_widget(form.phoneNumber) }}
            {{ form_errors(form.phoneNumber) }}
        {% else %}
            <p class="form-control-static">{{ user.phoneNumber }}</p>
            {% do form.phoneNumber.setRendered() %}
        {% endif %}
    </div>

    <div class="form-group">
        <label>Email :</label>
        {% if is_owner %}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        {% else %}
            <p class="form-control-static">{{ user.email }}</p>
            {% do form.email.setRendered() %}
        {% endif %}
    </div>

    <div class="form-group">
        <label>Campus :</label>
        {% if is_owner %}
            {{ form_widget(form.campus) }}
            {{ form_errors(form.campus) }}
        {% else %}
            <p class="form-control-static">{{ user.campus.name }}</p>
            {% do form.campus.setRendered() %}
        {% endif %}
    </div>

    {# ZONE MOT DE PASSE : Uniquement pour le propriétaire #}
    {% if is_owner %}
        <div class="form-group">
            {{ form_label(form.password.first, 'Nouveau mot de passe (laisser vide pour inchangé) :') }}
            {{ form_widget(form.password.first, {'attr': {'placeholder': 'Nouveau mot de passe'}}) }}
            {{ form_errors(form.password.first) }}
        </div>

        <div class="form-group">
            {{ form_label(form.password.second, 'Confirmer le mot de passe :') }}
            {{ form_widget(form.password.second) }}
            {{ form_errors(form.password.second) }}
        </div>
    {% else %}
        {% do form.password.setRendered() %}
    {% endif %}

    {# ZONE PHOTO #}
    <div class="form-group">
        <label>Photo de profil :</label>
        {% if user.profilePicture %}
            <div class="mb-2">
                <img src="{{ asset('uploads/avatars/' ~ user.profilePicture) }}" alt="Photo actuelle" width="80" class="img-thumbnail">
            </div>
        {% endif %}

        {% if is_owner %}
            {{ form_widget(form.profilePicture) }}
            {{ form_errors(form.profilePicture) }}
        {% else %}
            {% do form.profilePicture.setRendered() %}
        {% endif %}
    </div>

    {# BOUTON ENREGISTRER #}
    <div>
        <button type="submit" class="btn btn-update">
            {% if is_owner %}
                Enregistrer mes modifications
            {% else %}
                Enregistrer le statut (Admin)
            {% endif %}
        </button>
    </div>

    {{ form_end(form) }}

    <hr>

    {# 3. FORMULAIRE DE SUPPRESSION (Pour l'admin OU pour le propriétaire lui-même) #}
    {% if is_granted('ROLE_ADMIN') or is_owner %}
        <form method="post" action="{{ path('user_delete', {'id': user.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce profil ? Cette action est irréversible.');" class="mt-3">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
            <button type="submit" class="btn btn-danger">
                {% if is_owner %}
                    Supprimer mon compte définitivement
                {% else %}
                    Supprimer ce compte (Action Admin)
                {% endif %}
            </button>
        </form>
    {% endif %}
</div>
