{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
    <div>
        {# CAS 1 : L'utilisateur est DÉJÀ connecté #}
        {% if app.user %}
            <div>
                <h2>Vous êtes déjà connecté</h2>
                <p>Bonjour {{ app.user.userIdentifier }}, vous êtes actuellement authentifié.</p>
                <div class="form-actions">
                    <a href="{{ path('app_home') }}" class="btn-primary">Aller à l'accueil</a>
                    <a href="{{ logout_path() }}" class="link">Se déconnecter</a>
                </div>
            </div>

            {# CAS 2 : L'utilisateur est anonyme, on affiche le formulaire #}
        {% else %}
            <form method="post">
                {% if error %}
                    <div class="alert alert-danger">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <h1>Please sign in</h1>

                <div class="form-group">
                    <label for="inputEmail">Email</label>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                </div>

                <div class="form-group">
                    <label for="inputPassword">Password</label>
                    <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                </div>

                {# Jeton de sécurité CSRF #}
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <div class="form-group checkbox-group">
                    <input type="checkbox" id="remember_me" name="_remember_me" checked />
                    <label for="remember_me">Se souvenir de moi</label>
                </div>

                <div class="form-actions">
                    <button class="btn-primary" type="submit">
                        Sign in
                    </button>
                </div>
            </form>
        {% endif %}
    </div>
{% endblock %}
