{% extends 'base.html.twig' %}

{% block title %}Sortir.com — Accueil{% endblock %}

{% block body %}
    <main>
        {# ── Filtres ── #}

                <form class="event-filter-form" method="get" action="{{ path('app_home') }}">

                    <div class="filter-main-fields">

                        <div class="filter-field filter-search">
                            <label for="search" class="filter-label">Rechercher une sortie...</label>
                            <input type="text" name="search" id="search" class="filter-input"
                                   placeholder="Nom de la sortie..."
                                   value="{{ app.request.query.get('search') }}">
                        </div>

                        <div class="filter-field filter-campus">
                            <label for="campus" class="filter-label">Campus</label>
                            <select name="campus" id="campus" class="filter-select">
                                <option value="">Tous les campus</option>
                                {% for campus in campuses %}
                                    <option value="{{ campus.id }}"
                                        {{ app.request.query.get('campus') == campus.id ? 'selected' : '' }}>
                                        {{ campus.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="filter-field filter-date-start">
                            <label for="date_start" class="filter-label">Entre le</label>
                            <input type="date" name="date_start" id="date_start" class="filter-input"
                                   value="{{ app.request.query.get('date_start') }}">
                        </div>

                        <div class="filter-field filter-date-end">
                            <label for="date_end" class="filter-label">Et le</label>
                            <input type="date" name="date_end" id="date_end" class="filter-input"
                                   value="{{ app.request.query.get('date_end') }}">
                        </div>

                        <div class="filter-secondary-fields">

                            <div class="filter-checkbox-group">
                                <input class="filter-checkbox-input" type="checkbox" name="is_organizer"
                                       id="is_organizer" value="1"
                                    {{ app.request.query.get('is_organizer') ? 'checked' : '' }}>
                                <label class="filter-checkbox-label" for="is_organizer">
                                    Sorties dont je suis l'organisateur
                                </label>
                            </div>

                            <div class="filter-checkbox-group">
                                <input class="filter-checkbox-input" type="checkbox" name="is_registered"
                                       id="is_registered" value="1"
                                    {{ app.request.query.get('is_registered') ? 'checked' : '' }}>
                                <label class="filter-checkbox-label" for="is_registered">
                                    Sorties auxquelles je suis inscrit
                                </label>
                            </div>

                            <div class="filter-checkbox-group">
                                <input class="filter-checkbox-input" type="checkbox" name="show_past"
                                       id="show_past" value="1"
                                    {{ app.request.query.get('show_past') ? 'checked' : '' }}>
                                <label class="filter-checkbox-label" for="show_past">
                                    Sorties passées
                                </label>
                            </div>

                        </div>

                        <div class="filter-actions">
                            <button type="submit" class="filter-submit-btn">Rechercher</button>
                        </div>

                    </div>
                </form>


        {# ── Liste des sorties ── #}

        {% if events is empty %}
            <div class="alert alert-info">Aucune sortie ne correspond à vos critères.</div>
        {% else %}
            <div class="events-grid">
                {% for event in events %}

                    <div class="event-card status-{{ event.status.name|lower }}">

                        {# Header: Title + Status #}
                        <div class="card-header">
                            <span class="status-badge">{{ event.status.value }}</span>
                            <h3>{{ event.name }}</h3>
                        </div>

                        {# Body: Only the vital logistics #}
                        <div class="card-body">
                            <div class="meta-item">
                                <span class="icon">📅</span>
                                <time>{{ event.startTime|date('d/m/Y à H:i') }}</time>
                            </div>

                            <div class="meta-item">
                                <span class="icon">📍</span>
                                <span>{{ event.location.city.name }}</span>
                            </div>
                        </div>

                        {# Footer: Gauge + Call to Action #}
                        <div class="card-footer">
                            <div class="attendees-count">
                                👤 {{ event.users|length }} / {{ event.maxParticipants }} places
                            </div>

                            <a href="{{ path('events_details', {'id': event.id}) }}" class="cta-link">
                                Voir la sortie →
                            </a>
                        </div>

                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="margin-top-container">
            <a href="{{ path('events_create') }}" class="btn btn-success">+ Créer une sortie</a>
        </div>

    </main>
{% endblock %}
