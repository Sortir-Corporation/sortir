{% extends 'base.html.twig' %}

{% block title %}Sortir.com — Accueil{% endblock %}

{% block body %}
    <div class="container my-4">

        {# ── Filtres ── #}
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Filtrer les sorties</h5>
                <form method="get" action="{{ path('app_home') }}">
                    <div class="row g-3">

                        <div class="col-md-3">
                            <label for="campus" class="form-label">Campus</label>
                            <select name="campus" id="campus" class="form-select">
                                <option value="">Tous les campus</option>
                                {% for campus in campuses %}
                                    <option value="{{ campus.id }}"
                                        {{ app.request.query.get('campus') == campus.id ? 'selected' : '' }}>
                                        {{ campus.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label for="search" class="form-label">Rechercher</label>
                            <input type="text" name="search" id="search" class="form-control"
                                   placeholder="Nom de la sortie..."
                                   value="{{ app.request.query.get('search') }}">
                        </div>

                        <div class="col-md-2">
                            <label for="date_start" class="form-label">Entre le</label>
                            <input type="date" name="date_start" id="date_start" class="form-control"
                                   value="{{ app.request.query.get('date_start') }}">
                        </div>

                        <div class="col-md-2">
                            <label for="date_end" class="form-label">Et le</label>
                            <input type="date" name="date_end" id="date_end" class="form-control"
                                   value="{{ app.request.query.get('date_end') }}">
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">Rechercher</button>
                        </div>

                    </div>

                    <div class="row mt-3">
                        <div class="col-auto">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="is_organizer"
                                       id="is_organizer" value="1"
                                    {{ app.request.query.get('is_organizer') ? 'checked' : '' }}>
                                <label class="form-check-label" for="is_organizer">
                                    Sorties dont je suis l'organisateur
                                </label>
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="is_registered"
                                       id="is_registered" value="1"
                                    {{ app.request.query.get('is_registered') ? 'checked' : '' }}>
                                <label class="form-check-label" for="is_registered">
                                    Sorties auxquelles je suis inscrit
                                </label>
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="show_past"
                                       id="show_past" value="1"
                                    {{ app.request.query.get('show_past') ? 'checked' : '' }}>
                                <label class="form-check-label" for="show_past">
                                    Sorties passées
                                </label>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>

        {# ── Liste des sorties ── #}
        <h4 class="mb-3">Sorties à venir</h4>

        {% if events is empty %}
            <div class="alert alert-info">Aucune sortie ne correspond à vos critères.</div>
        {% else %}
            {% for event in events %}
                {% set badgeClass = 'bg-light text-dark' %}
                {% if event.status.value == 'Ouverte' %}
                    {% set badgeClass = 'bg-success' %}
                {% elseif event.status.value == 'Clôturée' %}
                    {% set badgeClass = 'bg-warning text-dark' %}
                {% elseif event.status.value == 'Annulée' %}
                    {% set badgeClass = 'bg-danger' %}
                {% elseif event.status.value == 'passée' %}
                    {% set badgeClass = 'bg-secondary' %}
                {% elseif event.status.value == 'Activité en cours' %}
                    {% set badgeClass = 'bg-info text-dark' %}
                {% endif %}

                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title mb-1">{{ event.name }}</h5>
                            <span class="badge {{ badgeClass }}">{{ event.status.value }}</span>
                        </div>
                        <p class="card-text mb-1">
                            <strong>Date :</strong> {{ event.startTime|date('d/m/Y à H:i') }}
                            &nbsp;|&nbsp;
                            <strong>Durée :</strong> {{ event.duration }} min
                        </p>
                        <p class="card-text mb-1">
                            <strong>Lieu :</strong> {{ event.location.name }}, {{ event.location.city.name }}
                            &nbsp;|&nbsp;
                            <strong>Campus :</strong> {{ event.campus.name }}
                        </p>
                        <p class="card-text mb-1">
                            <strong>Inscrits :</strong> {{ event.users|length }} / {{ event.maxParticipants }}
                            &nbsp;|&nbsp;
                            <strong>Organisateur :</strong> {{ event.organizer.firstName }} {{ event.organizer.lastName }}
                            &nbsp;|&nbsp;
                            <strong>Clôture :</strong> {{ event.registrationDeadline|date('d/m/Y') }}
                        </p>
                    </div>
                </div>
            {% endfor %}
        {% endif %}

        <div class="mt-4">
            <a href="{{ path('events_create') }}" class="btn btn-success">+ Créer une sortie</a>
        </div>

    </div>
{% endblock %}
